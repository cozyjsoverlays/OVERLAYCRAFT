# ─────────────────────────────────────────────────────────────────────────────
# CozyOverlays — environment variables
# Copy to `.env` (gitignored) and fill in. NEXT_PUBLIC_* are exposed to the
# browser; everything else is server-only and must NEVER be prefixed NEXT_PUBLIC.
# ─────────────────────────────────────────────────────────────────────────────

# ── PayPal ───────────────────────────────────────────────────────────────────
# Client ID is public (used by the JS SDK in the browser).
NEXT_PUBLIC_PAYPAL_CLIENT_ID=
# Secret is server-only. Get both from https://developer.paypal.com/dashboard/
PAYPAL_CLIENT_SECRET=
# "sandbox" for testing, "live" for production.
PAYPAL_ENV=sandbox

# ── Database ─────────────────────────────────────────────────────────────────
# Dev (SQLite):   file:./dev.db
# Prod (Postgres): postgresql://USER:PASS@HOST:5432/DB?sslmode=require
# (When moving to Postgres, also change `provider` in prisma/schema.prisma.)
DATABASE_URL="file:./dev.db"

# ── Email (Resend) ───────────────────────────────────────────────────────────
RESEND_API_KEY=
# Must be a verified sender/domain in Resend, e.g. "CozyOverlays <hello@cozyoverlays.com>"
EMAIL_FROM=

# ── File storage (Cloudflare R2 / S3-compatible) ─────────────────────────────
# R2 example endpoint: https://<account_id>.r2.cloudflarestorage.com
STORAGE_ENDPOINT=
STORAGE_BUCKET=
STORAGE_ACCESS_KEY_ID=
STORAGE_SECRET_ACCESS_KEY=
# Optional: region (R2 ignores it; S3 needs it). Defaults to "auto".
STORAGE_REGION=auto

# ── Security ─────────────────────────────────────────────────────────────────
# Long random string used to HMAC-sign download tokens. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
DOWNLOAD_TOKEN_SECRET=
# Password for the /admin dashboard (product management + Etsy sync).
ADMIN_PASSWORD=
# Secret used to sign the admin session cookie. Generate like DOWNLOAD_TOKEN_SECRET.
# If unset, falls back to ADMIN_PASSWORD (set this explicitly in production).
SESSION_SECRET=
# Protects the Vercel Cron endpoint (/api/cron/etsy-sync). Generate a random string.
CRON_SECRET=

# ── Etsy sync (OPTIONAL) ─────────────────────────────────────────────────────
# The site runs 100% without these — they only enable importing Etsy listings.
# Requires an APPROVED Etsy app: https://www.etsy.com/developers/register
# Approval for new apps is selective; the admin panel is the working default.
ETSY_API_KEY=
ETSY_CLIENT_ID=
ETSY_CLIENT_SECRET=
ETSY_SHOP_ID=                # Your numeric CozyJsStudio shop id
ETSY_REDIRECT_URI=           # e.g. https://cozyoverlays.com/api/etsy/oauth/callback
ETSY_OAUTH_SCOPES=listings_r
# 64 hex chars (32 bytes) used to AES-256-GCM encrypt stored Etsy tokens. Generate:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TOKEN_ENCRYPTION_KEY=

# ── Site ─────────────────────────────────────────────────────────────────────
# Used for absolute URLs in emails, OG tags, sitemap. No trailing slash.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
